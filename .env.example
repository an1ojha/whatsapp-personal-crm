# Get a key from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional — must be a model your key can call
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional — only needed if your WhatsApp Desktop DB lives somewhere else.
# WHATSAPP_DB_PATH=/Users/you/Library/Group Containers/group.net.whatsapp.WhatsApp.shared/ChatStorage.sqlite

# Composio (https://platform.composio.dev/developers) — for Google Calendar from the Q&A tab.
# Paste your key in the Setup tab; the Connect Google Calendar button fills the rest.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=
COMPOSIO_AUTH_CONFIG_ID=
COMPOSIO_CONNECTION_ID=
